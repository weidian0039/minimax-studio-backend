# MiniMax Studio — Environment Variables Template
# Copy to .env.local for local development
# NEVER commit .env files to version control

# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─────────────────────────────────────────────────────────
# Database (SQLite for Phase 3, Postgres for Phase 4)
# ─────────────────────────────────────────────────────────
DB_PATH=./db/app.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─────────────────────────────────────────────────────────
# AI Provider — MiniMax
# ─────────────────────────────────────────────────────────
# Set to a real API key for live generation, or "mock" for picsum.photos fallback
MINIMAX_API_KEY=mock

# ─────────────────────────────────────────────────────────
# Email (nodemailer + Ethereal fallback)
# Leave EMAIL_HOST empty to use Ethereal test accounts (dev default)
# ─────────────────────────────────────────────────────────
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=MiniMax Studio <noreply@minimax.studio>

# ─────────────────────────────────────────────────────────
# Queue Processor
# ─────────────────────────────────────────────────────────
QUEUE_POLL_INTERVAL_MS=5000

# ─────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
